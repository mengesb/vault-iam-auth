<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" type="device">
  <diagram id="vault-iam-auth-data-flow" name="Data Flow (Sequence)">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- This diagram is best maintained via the Mermaid source (data-flow.mmd). -->
        <!-- The draw.io file embeds the rendered PNG for editability in draw.io. -->
        <!-- To regenerate: mmdc -i data-flow.mmd -o data-flow.png -->

        <mxCell id="note" value="This sequence diagram is maintained as Mermaid source in data-flow.mmd.&lt;br&gt;Render with: mmdc -i data-flow.mmd -o data-flow.png&lt;br&gt;&lt;br&gt;The Mermaid sequence diagram format does not map cleanly to draw.io&lt;br&gt;editable shapes. Use the .mmd file as the source of truth." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="500" height="100" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
