<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" type="device">
  <diagram id="vault-iam-auth-component" name="Component Detail">
    <mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ==================== TERRAFORM PLAN EXECUTION ==================== -->
        <mxCell id="tf_container" value="Terraform Plan Execution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;dashed=1;dashPattern=5 5;fontSize=14;fontStyle=1;verticalAlign=top;align=center;spacingTop=5;strokeColor=#2E7D32;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="400" height="520" as="geometry" />
        </mxCell>

        <!-- terraform init/plan -->
        <mxCell id="tf_init" value="terraform init / plan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="140" y="80" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- data.external -->
        <mxCell id="tf_ext" value="data.external.vault_auth&lt;br&gt;&lt;i&gt;program = aws/vault-iam-auth.sh&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="110" y="160" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- provider vault -->
        <mxCell id="tf_vault" value="provider vault&lt;br&gt;&lt;i&gt;(token from external)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="140" y="260" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- ephemeral resource -->
        <mxCell id="tf_ephem" value="ephemeral.vault_aws_access_credentials&lt;br&gt;&lt;i&gt;(reads AWS secrets engine)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="350" width="260" height="50" as="geometry" />
        </mxCell>

        <!-- provider aws -->
        <mxCell id="tf_aws" value="provider aws&lt;br&gt;&lt;i&gt;(access_key, secret_key, token)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="130" y="440" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- AWS Resources -->
        <mxCell id="tf_resources" value="AWS Resources&lt;br&gt;&lt;i&gt;(plan / apply)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="530" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Terraform internal edges -->
        <mxCell id="tf_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;" edge="1" source="tf_init" target="tf_ext" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tf_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;" edge="1" source="tf_ext" target="tf_vault" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tf_e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;" edge="1" source="tf_vault" target="tf_ephem" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tf_e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;" edge="1" source="tf_ephem" target="tf_aws" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tf_e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;" edge="1" source="tf_aws" target="tf_resources" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== VAULT-IAM-AUTH SCRIPTS ==================== -->
        <mxCell id="scripts_container" value="vault-iam-auth Scripts (AWS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;dashed=1;dashPattern=5 5;fontSize=14;fontStyle=1;verticalAlign=top;align=center;spacingTop=5;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="40" width="560" height="350" as="geometry" />
        </mxCell>

        <!-- vault-iam-auth.sh main -->
        <mxCell id="main_sh" value="aws/vault-iam-auth.sh&lt;br&gt;&lt;i&gt;(entry point)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="80" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Shell Libraries container -->
        <mxCell id="libs_container" value="Shell Libraries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;dashed=1;dashPattern=3 3;fontSize=11;fontStyle=2;verticalAlign=top;align=center;spacingTop=3;strokeColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="520" y="170" width="520" height="200" as="geometry" />
        </mxCell>

        <!-- aws-credentials.sh -->
        <mxCell id="aws_creds_sh" value="aws-credentials.sh&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:9px&quot;&gt;• aws_instance_profile_name()&lt;br&gt;• aws_credentials()&lt;br&gt;• aws_access_key_id()&lt;br&gt;• aws_secret_access_key()&lt;br&gt;• aws_session_token()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="540" y="200" width="170" height="150" as="geometry" />
        </mxCell>

        <!-- aws4-sign.sh -->
        <mxCell id="aws4_sh" value="aws4-sign.sh&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:9px&quot;&gt;• AWS4_HMAC_SHA256()&lt;br&gt;• AWS4_SHA256()&lt;br&gt;• AWS4_BASE64()&lt;br&gt;• AWS4_SIGN()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="730" y="200" width="150" height="130" as="geometry" />
        </mxCell>

        <!-- parse-url.sh -->
        <mxCell id="parse_sh" value="parse-url.sh&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:9px&quot;&gt;• parse_url()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="900" y="200" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- Source edges from main -->
        <mxCell id="src_e1" value="source" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;fontSize=9;dashed=1;" edge="1" source="main_sh" target="aws_creds_sh" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="src_e2" value="source" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;fontSize=9;dashed=1;" edge="1" source="main_sh" target="aws4_sh" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="src_e3" value="source" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;fontSize=9;dashed=1;" edge="1" source="main_sh" target="parse_sh" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== EC2 METADATA SERVICE ==================== -->
        <mxCell id="meta_container" value="EC2 Instance Metadata Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;dashed=1;dashPattern=5 5;fontSize=12;fontStyle=1;verticalAlign=top;align=center;spacingTop=5;strokeColor=#C62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="430" width="340" height="120" as="geometry" />
        </mxCell>

        <!-- EC2 Metadata -->
        <mxCell id="ec2_md" value="EC2 Metadata&lt;br&gt;&lt;i&gt;169.254.169.254&lt;br&gt;/meta-data/iam/security-credentials/&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="465" width="220" height="65" as="geometry" />
        </mxCell>

        <!-- ==================== VAULT SERVER ==================== -->
        <mxCell id="vault_container" value="HashiCorp Vault Server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;dashed=1;dashPattern=5 5;fontSize=14;fontStyle=1;verticalAlign=top;align=center;spacingTop=5;strokeColor=#F9A825;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="590" width="560" height="180" as="geometry" />
        </mxCell>

        <!-- POST /v1/auth/aws/login -->
        <mxCell id="v_auth_aws" value="POST /v1/auth/aws/login&lt;br&gt;&lt;i&gt;{role, iam_http_request_method,&lt;br&gt;iam_request_url, iam_request_body,&lt;br&gt;iam_request_headers}&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="630" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- GET /v1/aws/creds/:role -->
        <mxCell id="v_aws_se" value="GET /v1/aws/creds/:role&lt;br&gt;&lt;i&gt;or /v1/aws/sts/:role&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="720" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== AWS STS ==================== -->
        <mxCell id="sts_container" value="AWS STS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;dashed=1;dashPattern=5 5;fontSize=12;fontStyle=1;verticalAlign=top;align=center;spacingTop=5;strokeColor=#C62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="810" width="560" height="120" as="geometry" />
        </mxCell>

        <!-- GetCallerIdentity -->
        <mxCell id="sts_gci" value="GetCallerIdentity&lt;br&gt;&lt;i&gt;(Vault replays signed request)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="850" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- AssumeRole -->
        <mxCell id="sts_assume" value="AssumeRole / GetFederationToken&lt;br&gt;&lt;i&gt;(Secrets engine generates creds)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="770" y="850" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- ==================== DATA FLOW EDGES ==================== -->

        <!-- External data source executes main script -->
        <mxCell id="flow_e1" value="executes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;fontSize=10;fontStyle=1;" edge="1" source="tf_ext" target="main_sh" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- aws-credentials.sh -> EC2 metadata -->
        <mxCell id="flow_e2" value="curl IMDS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=1.5;fontSize=9;" edge="1" source="aws_creds_sh" target="ec2_md" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- EC2 metadata -> aws-credentials.sh (response) -->
        <mxCell id="flow_e3" value="AccessKeyId, SecretAccessKey, SessionToken" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=1;fontSize=9;dashed=1;" edge="1" source="ec2_md" target="aws_creds_sh" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="670" y="460" />
              <mxPoint x="625" y="460" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- aws4-sign.sh produces signed headers -> main -->
        <mxCell id="flow_e4" value="Signed headers (Authorization, x-amz-date, x-amz-security-token)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;strokeWidth=1.5;fontSize=9;" edge="1" source="aws4_sh" target="main_sh" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="880" y="265" />
              <mxPoint x="880" y="105" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- main.sh returns JSON to external data source -->
        <mxCell id="flow_e5" value="JSON payload (base64 encoded)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;fontSize=9;fontStyle=1;" edge="1" source="main_sh" target="tf_ext" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="480" y="105" />
              <mxPoint x="480" y="185" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Vault provider -> auth/aws/login -->
        <mxCell id="flow_e6" value="Login with signed payload" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#F9A825;strokeWidth=2;fontSize=9;fontStyle=1;" edge="1" source="tf_vault" target="v_auth_aws" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="220" y="620" />
              <mxPoint x="220" y="665" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Vault auth -> STS GetCallerIdentity -->
        <mxCell id="flow_e7" value="Replay signed request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=1.5;fontSize=9;" edge="1" source="v_auth_aws" target="sts_gci" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- STS confirms -> Vault -->
        <mxCell id="flow_e8" value="Identity confirmed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=1;fontSize=9;dashed=1;" edge="1" source="sts_gci" target="v_auth_aws" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="750" y="875" />
              <mxPoint x="750" y="665" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Vault returns client_token -->
        <mxCell id="flow_e9" value="client_token" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#F9A825;strokeWidth=2;fontSize=9;fontStyle=1;" edge="1" source="v_auth_aws" target="tf_vault" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="460" y="700" />
              <mxPoint x="460" y="310" />
              <mxPoint x="300" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Ephemeral resource -> AWS secrets engine -->
        <mxCell id="flow_e10" value="Read creds" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#F9A825;strokeWidth=1.5;fontSize=9;" edge="1" source="tf_ephem" target="v_aws_se" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- AWS secrets engine -> STS AssumeRole -->
        <mxCell id="flow_e11" value="Generate via" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=1.5;fontSize=9;" edge="1" source="v_aws_se" target="sts_assume" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- STS returns creds -> secrets engine -->
        <mxCell id="flow_e12" value="Temporary creds" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=1;fontSize=9;dashed=1;" edge="1" source="sts_assume" target="v_aws_se" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="980" y="875" />
              <mxPoint x="980" y="740" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Secrets engine returns to ephemeral -->
        <mxCell id="flow_e13" value="access_key, secret_key, security_token, lease_id" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#F9A825;strokeWidth=1.5;fontSize=9;" edge="1" source="v_aws_se" target="tf_ephem" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="80" y="740" />
              <mxPoint x="80" y="375" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
